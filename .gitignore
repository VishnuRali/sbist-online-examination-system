node_modules/
.pnp
.pnp.js

# ─── Environment & Secrets ──────────────────────────────
.env
.env.local
.env.*.local
*.env

# ─── Build & Dist ───────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── Logs ───────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Cache & Temp ───────────────────────────────────────
.cache/
.parcel-cache/
.vite/
*.local
*.tmp
*.temp

# ─── OS Files ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ───────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

