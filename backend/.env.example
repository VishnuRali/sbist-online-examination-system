PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sbit_exam?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Super Admin Seed Credentials (used by seed-admin.js)
SUPER_ADMIN_EMAIL=admin@yourdomain.edu
SUPER_ADMIN_PASSWORD=YourSecurePassword123!
SUPER_ADMIN_EMPLOYEE_ID=SUPERADMIN

# Email Configuration (Gmail SMTP with App Password)
GMAIL_USER=your_notifications_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# Exam Portal URL (used in email links)
EXAM_URL=http://localhost:5173

# Google Sheets Integration (for Google Form response syncing)
GOOGLE_SHEET_ID=your_google_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Admin Secret (for legacy admin registration route)
ADMIN_SECRET=your_admin_registration_secret
